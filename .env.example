# JWT
BASE_JWT_SECRET=change-me-to-a-random-secret
BASE_JWT_ACCESS_TTL=7200
BASE_JWT_REFRESH_TTL=604800

# 数据库主库
RDB_MAIN_AUTO_MIGRATE=false
RDB_MAIN_DRIVER=postgresql
RDB_MAIN_HOST=127.0.0.1
RDB_MAIN_PORT=5432
RDB_MAIN_USERNAME=postgres
RDB_MAIN_PASSWORD=your_password
RDB_MAIN_DATABASE=domaingodb

# 数据库从库
RDB_SECONDARY_DRIVER=postgresql
RDB_SECONDARY_HOST=127.0.0.1
RDB_SECONDARY_PORT=5432
RDB_SECONDARY_USERNAME=postgres
RDB_SECONDARY_PASSWORD=your_password
RDB_SECONDARY_DATABASE=domaingodb

# 网关 etcd（多个地址用逗号分隔）
BASE_GATEWAY_PROVIDER_ENDPOINTS=127.0.0.1:2379
BASE_GATEWAY_PROVIDER_USERNAME=
BASE_GATEWAY_PROVIDER_PASSWORD=

# 注册中心 etcd（多个地址用逗号分隔）
BASE_REGISTRY_PROVIDER_ENDPOINTS=127.0.0.1:2379
BASE_REGISTRY_PROVIDER_USERNAME=
BASE_REGISTRY_PROVIDER_PASSWORD=
